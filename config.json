{
  "version": "2.7.0",
  "paths": {
    "root": "F:/imonlinegaming",
    "agent_root": "F:/imonlinegaming/LocalCodeAgent",
    "projects": "F:/imonlinegaming/LocalCodeAgent/Projects",
    "logs": "F:/imonlinegaming/LocalCodeAgent/logs",
    "models": "F:/imonlinegaming/LocalCodeAgent/models",
    "rag_index": "F:/imonlinegaming/LocalCodeAgent/RAG_Index",
    "coders_guild": "F:/imonlinegaming/CodersGuild",
    "scan_roots": ["F:/imonlinegaming"]
  },
  "hardware": {
    "gpu_name": "NVIDIA GeForce GTX 1070",
    "vram_mb": 8192,
    "system_ram_gb": 32,
    "n_gpu_layers": 28,
    "n_ctx": 4096,
    "n_threads": 8,
    "n_batch": 512
  },
  "llm": {
    "model_filename": "model.gguf",
    "temperature": 0.2,
    "max_tokens": 2048,
    "top_p": 0.9,
    "repeat_penalty": 1.1
  },
  "scanner": {
    "max_files": 2000,
    "max_file_bytes": 524288,
    "content_preview_chars": 4000,
    "skip_dirs": [
      "node_modules", ".git", "__pycache__", "venv", "env", ".venv",
      "site-packages", ".idea", ".vscode", "target", "RAG_Index",
      "models", "build", "dist", ".grok"
    ],
    "allowed_extensions": [
      ".py", ".rs", ".js", ".ts", ".tsx", ".html", ".css", ".bat",
      ".md", ".toml", ".json", ".txt", ".sh", ".ps1", ".yaml", ".yml"
    ]
  },
  "rag": {
    "collection_name": "local_code_agent",
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "top_k": 5,
    "enabled": true
  },
  "safety": {
    "versioning_enabled": true,
    "self_debug_enabled": true
  }
}
